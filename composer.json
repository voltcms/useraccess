{
    "name": "voltcms/useraccess",
    "description": "UserAccess",
    "keywords": ["php"],
    "license": "ISC",
    "authors": [
        {
            "name": "Jannis Rondorf",
            "email": "github@jrondorf.de"
        }
    ],
    "type": "project",
    "require": {
        "php": ">=8.2",
        "voltcms/filedb": "^2",
        "bramus/router": "^1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13",
        "phpstan/phpstan": "*",
        "squizlabs/php_codesniffer": "*"
    },
    "autoload": {
        "psr-4": {
            "VoltCMS\\UserAccess\\": "src/"
        }
    },
    "scripts": {
        "build": "composer update --optimize-autoloader --classmap-authoritative",
        "test": "./vendor/bin/phpunit",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf"
    }
}
